            "command": "python -X utf8 .claude/hooks/invoke-python-hook.py .claude/hooks/validate-course-map.py"
          },
          {
            "type": "command",
            "command": "python -X utf8 .claude/hooks/invoke-python-hook.py .claude/hooks/validate-paragraph-numbering.py"
          },
          {
            "type": "command",
